# WiFi credentials for the ESP32 connect demo.
#
# Copy this file to `wifi_creds.env` (gitignored — never committed) and fill in
# your network. `build.rs` reads it and passes the values to the compiler; the
# firmware uses them but never prints them over serial.
#
#     cp wifi_creds.env.example wifi_creds.env
#     $EDITOR wifi_creds.env

WIFI_SSID=your-network-name
WIFI_PASS=your-password
